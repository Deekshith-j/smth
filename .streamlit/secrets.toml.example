# ─── Streamlit Cloud Secrets Template ────────────────────────────────────────
# Go to: share.streamlit.io → Your App → Settings → Secrets
# Paste the contents below (with your real values filled in)

GROQ_API_KEY = "gsk_your_groq_key_here"
GOOGLE_API_KEY = "your_gemini_key_here"
OPENAI_API_KEY = "your_openai_key_here"

LANGCHAIN_API_KEY = "lsv2_pt_your_langsmith_key_here"
LANGCHAIN_TRACING_V2 = "true"
LANGCHAIN_PROJECT = "zyro-rag-challenge"
LANGCHAIN_ENDPOINT = "https://api.smith.langchain.com"

LLM_PROVIDER = "groq"
LLM_MODEL = "llama-3.3-70b-versatile"

STREAMLIT_LINK = "https://your-app.streamlit.app"
LANGSMITH_LINK = "https://smith.langchain.com/public/xxx/r"
