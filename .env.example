# ─── Copy this file to .env and fill in your keys ────────────────────────────

# LLM Configuration
LLM_PROVIDER=groq                        # Options: groq | gemini | openai
LLM_MODEL=llama-3.3-70b-versatile        # Groq default

# API Keys — get free keys below:
GROQ_API_KEY=your_groq_api_key_here      # https://console.groq.com
GOOGLE_API_KEY=your_gemini_api_key_here  # https://aistudio.google.com
OPENAI_API_KEY=your_openai_api_key_here  # https://platform.openai.com

# LangSmith Tracing — get free key at https://smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=zyro-rag-challenge
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Submission Links (fill after deploying to Streamlit Cloud)
STREAMLIT_LINK=https://your-app.streamlit.app
LANGSMITH_LINK=https://smith.langchain.com/public/xxx/r
